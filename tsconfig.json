{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "strict": true,
    "strictNullChecks": false,
  "strictFunctionTypes": false,
  "strictBindCallApply": false,
  "noImplicitThis": false,
  "noImplicitReturns": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
